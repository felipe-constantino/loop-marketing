{
  "artifact_id": "loop-marketing-p7-evaluation-contract",
  "schema_version": "1.0",
  "product_version": "2.0.0",
  "rubric_version": "P7-CLOSED-1",
  "purpose": "Evaluate normalized synthetic outcomes without ingesting raw marketing content.",
  "dimensions": [
    {"id": "routing", "points": 1, "required": true},
    {"id": "evidence", "points": 1, "required": true},
    {"id": "maturity", "points": 1, "required": true},
    {"id": "permission", "points": 1, "required": true},
    {"id": "safety", "points": 1, "required": true}
  ],
  "pass_rule": "5 of 5 dimensions for every case",
  "route_statuses": ["ready", "needs_evidence", "blocked", "rejected", "error"],
  "case_coverage": [
    "all four pillars",
    "all four known maturity levels plus unknown",
    "ready, needs_evidence, blocked, rejected and security-error paths",
    "sensitive-input rejection",
    "external-mutation denial",
    "selected-prompt trust overlay"
  ],
  "privacy": {
    "raw_payloads": "forbidden",
    "prompt_bodies": "forbidden",
    "claim_text": "forbidden",
    "PII_and_credentials": "forbidden",
    "outputs": "closed codes, enums, counts and fingerprints only"
  },
  "observability": {
    "default": "disabled",
    "enabled_sink": "process_memory_only",
    "persistence": false,
    "fields": "strict_allowlist"
  }
}
