{
  "artifact_id": "P7-OBS-DESIGN-001",
  "schema_version": "1.0",
  "status": "implemented",
  "scope": "Privacy-safe, deterministic audit metadata for the local Loop Marketing runtime.",
  "implementation": {
    "module": "candidate/loop-marketing-v2/src/loop_marketing_runtime/observability.py",
    "tests": "candidate/loop-marketing-v2/tests/test_observability.py",
    "python": "3.9+ stdlib only"
  },
  "defaults": {
    "collection_enabled": false,
    "persistence_enabled": false,
    "sink": "none",
    "clock": "none",
    "random_source": "none"
  },
  "trust_boundary": {
    "accepted": [
      "enumerated event type",
      "enumerated outcome",
      "enumerated dimensions",
      "bounded integer counters"
    ],
    "not_accepted": [
      "raw request or response payload",
      "prompt body or canonical tactic body",
      "claim text",
      "PII or credentials",
      "local or remote paths",
      "free-form messages",
      "timestamps or exact durations"
    ],
    "failure_behavior": "Fail closed with a constant error code and message that do not echo rejected input."
  },
  "record_contract": {
    "schema_version": "1.0",
    "top_level_fields": [
      "schema_version",
      "event_type",
      "outcome",
      "dimensions",
      "metrics",
      "record_fingerprint"
    ],
    "event_type_enum": [
      "route_evaluated",
      "handoff_evaluated",
      "integration_evaluated",
      "permission_evaluated",
      "security_denial",
      "evaluation_completed"
    ],
    "outcome_enum": [
      "passed",
      "failed",
      "blocked",
      "denied",
      "error"
    ],
    "dimension_allowlist": {
      "component": [
        "router",
        "specialist",
        "handoff",
        "integration",
        "security",
        "evaluator"
      ],
      "operation": [
        "routing",
        "evidence",
        "maturity",
        "permission",
        "safety",
        "aggregate"
      ],
      "pillar": [
        "none",
        "loop_planning",
        "verbalizar",
        "orientar",
        "ampliar",
        "refinar"
      ],
      "maturity": [
        "none",
        "unknown",
        "nascente",
        "em_desenvolvimento",
        "maduro",
        "avancado"
      ],
      "permission": [
        "none",
        "read_only",
        "local_state",
        "external_mutation"
      ],
      "duration_bucket": [
        "not_measured",
        "under_10ms",
        "under_100ms",
        "under_1s",
        "over_1s"
      ],
      "error_family": [
        "none",
        "input",
        "contract",
        "evidence",
        "maturity",
        "permission",
        "safety",
        "state",
        "internal"
      ]
    },
    "metric_allowlist": {
      "item_count": {
        "type": "integer",
        "minimum": 0,
        "maximum": 1000000
      },
      "violation_count": {
        "type": "integer",
        "minimum": 0,
        "maximum": 1000000
      }
    },
    "record_fingerprint": "SHA-256 over the sanitized canonical record without the fingerprint field."
  },
  "runtime_behavior": {
    "disabled_emit": "Return null without constructing or retaining a record.",
    "enabled_emit": "Validate, build, copy into process memory, and return a defensive copy.",
    "export": "Return immutable tuple semantics with recursively defensive record copies.",
    "persistence": "No persistent, file, network, console, or third-party sink exists in this workstream."
  },
  "security_invariants": [
    "No API parameter can carry a raw payload or prompt.",
    "Unknown dimensions and metrics are rejected.",
    "Arbitrary error strings are replaced by a closed error-family enum.",
    "The default constructor produces no records and performs no audit processing.",
    "Equivalent metadata produces byte-equivalent logical records and the same fingerprint.",
    "Caller-owned inputs and returned records cannot mutate retained records."
  ],
  "verification": {
    "scope": "new P7 observability tests only",
    "command": "PYTHONPATH=candidate/loop-marketing-v2/src python3 -m unittest discover -s candidate/loop-marketing-v2/tests -p 'test_observability.py' -v",
    "expected_test_count": 5
  }
}
