{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://loop-marketing.local/schemas/event-2.0.json",
  "title": "Loop Marketing v2 append-only event transaction record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "transaction_id",
    "project_ref",
    "expected_state_revision",
    "resulting_state_revision",
    "committed_at",
    "integrated_by_role",
    "reducer_version",
    "idempotency_key",
    "previous_record_hash",
    "record_hash",
    "events"
  ],
  "properties": {
    "schema_version": {
      "const": "2.0"
    },
    "record_type": {
      "const": "event_transaction"
    },
    "transaction_id": {
      "type": "string",
      "pattern": "^tx_[a-z0-9][a-z0-9_-]{2,127}$"
    },
    "project_ref": {
      "$ref": "#/$defs/reference"
    },
    "expected_state_revision": {
      "type": "integer",
      "minimum": 0
    },
    "resulting_state_revision": {
      "type": "integer",
      "minimum": 1
    },
    "committed_at": {
      "$ref": "#/$defs/dateTime"
    },
    "integrated_by_role": {
      "const": "loop_planning"
    },
    "reducer_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "idempotency_key": {
      "type": "string",
      "pattern": "^idem_[a-z0-9][a-z0-9_-]{2,127}$"
    },
    "previous_record_hash": {
      "$ref": "#/$defs/chainHead"
    },
    "record_hash": {
      "$ref": "#/$defs/sha256"
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/event"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096
    },
    "shortText": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512
    },
    "reference": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": "^[^\\u0000-\\u001f\\u007f]+$"
    },
    "projectId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,62}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "role": {
      "type": "string",
      "enum": [
        "loop_planning",
        "verbalizar",
        "orientar",
        "ampliar",
        "refinar"
      ]
    },
    "maturity": {
      "type": "string",
      "enum": [
        "nascente",
        "em_desenvolvimento",
        "maduro",
        "avancado",
        "unknown"
      ]
    },
    "mode": {
      "type": "string",
      "enum": [
        "completo",
        "parcial",
        "minimo_viavel"
      ]
    },
    "referenceArray": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/reference"
      }
    },
    "chainHead": {
      "anyOf": [
        {
          "const": "GENESIS"
        },
        {
          "$ref": "#/$defs/sha256"
        }
      ]
    },
    "claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim_id",
        "kind",
        "text",
        "provenance",
        "confidence"
      ],
      "properties": {
        "claim_id": {
          "$ref": "#/$defs/reference"
        },
        "kind": {
          "type": "string",
          "enum": [
            "fact",
            "user_interpretation",
            "symptom",
            "hypothesis"
          ]
        },
        "text": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "provenance": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "source_ref": {
              "$ref": "#/$defs/reference"
            },
            "observed_at": {
              "$ref": "#/$defs/dateTime"
            },
            "rationale": {
              "$ref": "#/$defs/nonEmptyString"
            }
          }
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "payload_version",
        "claims",
        "data"
      ],
      "properties": {
        "payload_version": {
          "const": "1.0"
        },
        "claims": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/claim"
          }
        },
        "data": {
          "type": "object"
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "event_id",
        "event_type",
        "project_ref",
        "cycle_id",
        "actor_role",
        "command_id",
        "occurred_at",
        "state_revision",
        "resulting_state_revision",
        "event_sequence",
        "transaction_id",
        "effect",
        "idempotency_key",
        "previous_event_hash",
        "event_hash",
        "evidence_refs",
        "payload"
      ],
      "properties": {
        "schema_version": {
          "const": "2.0"
        },
        "event_id": {
          "type": "string",
          "pattern": "^evt_[a-z0-9][a-z0-9_-]{2,127}$"
        },
        "event_type": {
          "type": "string",
          "enum": [
            "amplification_plan_proposed",
            "bottleneck_accepted",
            "bottleneck_observation_emitted",
            "bottleneck_rejected",
            "cadence_plan_proposed",
            "channel_plan_proposed",
            "cross_pillar_implication_issued",
            "cross_validation_completed",
            "cross_validation_requested",
            "cycle_close_recommended",
            "data_gap_reported",
            "eligibility_rule_proposed",
            "experiment_created_as_proposed",
            "experiment_result_interpreted",
            "experiment_transition_evidence_validated",
            "experiment_transition_rejected",
            "frequency_cap_proposed",
            "handoff_issued",
            "learning_recorded",
            "lifecycle_event_rule_proposed",
            "lifecycle_model_proposed",
            "maturity_classified",
            "message_contract_published",
            "message_decision_proposed",
            "operational_timing_rule_proposed",
            "performance_diagnosis_recorded",
            "personalization_rule_proposed",
            "pillar_scores_recorded",
            "route_plan_issued",
            "scope_violation_reported",
            "segment_definition_proposed",
            "test_opportunity_proposed",
            "touchpoint_rule_proposed"
          ]
        },
        "project_ref": {
          "$ref": "#/$defs/reference"
        },
        "cycle_id": {
          "$ref": "#/$defs/reference"
        },
        "actor_role": {
          "$ref": "#/$defs/role"
        },
        "command_id": {
          "type": "string",
          "enum": [
            "loop.ampliar",
            "loop.orientar",
            "loop.planning",
            "loop.projeto",
            "loop.refinar",
            "loop.verbalizar"
          ]
        },
        "occurred_at": {
          "$ref": "#/$defs/dateTime"
        },
        "state_revision": {
          "type": "integer",
          "minimum": 0
        },
        "resulting_state_revision": {
          "type": "integer",
          "minimum": 1
        },
        "event_sequence": {
          "type": "integer",
          "minimum": 1
        },
        "transaction_id": {
          "type": "string",
          "pattern": "^tx_[a-z0-9][a-z0-9_-]{2,127}$"
        },
        "effect": {
          "type": "string",
          "enum": [
            "observation",
            "proposal",
            "transition_validation",
            "integration"
          ]
        },
        "idempotency_key": {
          "type": "string",
          "pattern": "^idem_[a-z0-9][a-z0-9_-]{2,127}$"
        },
        "previous_event_hash": {
          "$ref": "#/$defs/chainHead"
        },
        "event_hash": {
          "$ref": "#/$defs/sha256"
        },
        "evidence_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/reference"
          }
        },
        "payload": {
          "$ref": "#/$defs/payload"
        }
      }
    }
  },
  "x-loop-contract": {
    "canonical_path": ".loop-marketing/state/projects/<project_id>/events.jsonl",
    "authority_by_role": {
      "loop_planning": [
        "maturity_classified",
        "pillar_scores_recorded",
        "bottleneck_accepted",
        "bottleneck_rejected",
        "route_plan_issued",
        "handoff_issued",
        "cross_validation_requested",
        "cross_validation_completed",
        "scope_violation_reported",
        "cycle_close_recommended"
      ],
      "verbalizar": [
        "message_decision_proposed",
        "message_contract_published",
        "test_opportunity_proposed",
        "bottleneck_observation_emitted",
        "data_gap_reported",
        "handoff_issued"
      ],
      "orientar": [
        "lifecycle_model_proposed",
        "segment_definition_proposed",
        "eligibility_rule_proposed",
        "lifecycle_event_rule_proposed",
        "personalization_rule_proposed",
        "test_opportunity_proposed",
        "bottleneck_observation_emitted",
        "data_gap_reported",
        "handoff_issued"
      ],
      "ampliar": [
        "channel_plan_proposed",
        "touchpoint_rule_proposed",
        "operational_timing_rule_proposed",
        "frequency_cap_proposed",
        "cadence_plan_proposed",
        "amplification_plan_proposed",
        "test_opportunity_proposed",
        "bottleneck_observation_emitted",
        "data_gap_reported",
        "handoff_issued"
      ],
      "refinar": [
        "performance_diagnosis_recorded",
        "experiment_created_as_proposed",
        "experiment_transition_evidence_validated",
        "experiment_transition_rejected",
        "experiment_result_interpreted",
        "learning_recorded",
        "cross_pillar_implication_issued",
        "bottleneck_observation_emitted",
        "data_gap_reported",
        "handoff_issued"
      ]
    },
    "command_contract": {
      "loop.planning": {
        "canonical": "/loop-planning",
        "legacy_alias": "/loop-planning-agent",
        "role": "loop_planning"
      },
      "loop.verbalizar": {
        "canonical": "/verbalizar",
        "legacy_alias": "/verbalizar-agent",
        "role": "verbalizar"
      },
      "loop.orientar": {
        "canonical": "/orientar",
        "legacy_alias": "/orientar-agent",
        "role": "orientar"
      },
      "loop.ampliar": {
        "canonical": "/ampliar",
        "legacy_alias": "/ampliar-agent",
        "role": "ampliar"
      },
      "loop.refinar": {
        "canonical": "/refinar",
        "legacy_alias": "/refinar-agent",
        "role": "refinar"
      },
      "loop.projeto": {
        "canonical": "/projeto",
        "legacy_alias": "/projeto-template",
        "role": "loop_planning"
      }
    },
    "canonical_event_type_count": 33,
    "hash_canonicalization": "RFC 8785 JSON; exclude event_hash for event hashes and record_hash for transaction hashes.",
    "revision_rule": "One committed transaction advances one state revision; all nested events share the expected and resulting revisions.",
    "audit_records_outside_domain_authority": [
      "legacy.imported",
      "recovery",
      "rollback"
    ],
    "idempotency": {
      "same_transaction_or_event_identifiers_and_content": "noop",
      "same_identifier_with_different_content": "reject",
      "partial_batch_retry": "reject"
    },
    "experiment_state_machine": {
      "create": {
        "from": null,
        "to": "proposed",
        "rule_id": "RTE-EXP-001",
        "required_evidence": [
          {
            "evidence_key": "hypothesis",
            "description": "hypothesis with specific change and measurable expected result"
          },
          {
            "evidence_key": "isolated_variable_or_multivariate_design",
            "description": "one isolated variable or explicit multivariate design"
          },
          {
            "evidence_key": "control_definition",
            "description": "control definition"
          },
          {
            "evidence_key": "success_metric_and_target",
            "description": "numeric success metric and target set before launch"
          },
          {
            "evidence_key": "minimum_sample_rule",
            "description": "minimum sample rule"
          },
          {
            "evidence_key": "duration_and_early_stop_rule",
            "description": "minimum duration and early-stop rule"
          },
          {
            "evidence_key": "post_test_thresholds",
            "description": "post-test decision thresholds"
          },
          {
            "evidence_key": "owner_and_created_at",
            "description": "owner and creation timestamp"
          }
        ]
      },
      "approve": {
        "from": "proposed",
        "to": "approved",
        "rule_id": "RTE-EXP-002",
        "required_evidence": [
          {
            "evidence_key": "approval_event_id",
            "description": "approval event ID"
          },
          {
            "evidence_key": "approver_identity",
            "description": "approver identity"
          },
          {
            "evidence_key": "approved_scope",
            "description": "approved scope"
          },
          {
            "evidence_key": "approval_timestamp",
            "description": "approval timestamp"
          }
        ]
      },
      "instrument": {
        "from": "approved",
        "to": "instrumented",
        "rule_id": "RTE-EXP-003",
        "required_evidence": [
          {
            "evidence_key": "instrumentation_record_id",
            "description": "instrumentation record ID"
          },
          {
            "evidence_key": "event_or_metric_schema",
            "description": "event or metric schema"
          },
          {
            "evidence_key": "assignment_mechanism",
            "description": "assignment mechanism"
          },
          {
            "evidence_key": "qa_result",
            "description": "QA result"
          },
          {
            "evidence_key": "sample_plan",
            "description": "sample plan"
          }
        ]
      },
      "launch": {
        "from": "instrumented",
        "to": "running",
        "rule_id": "RTE-EXP-004",
        "required_evidence": [
          {
            "evidence_key": "launch_event_id",
            "description": "launch event ID"
          },
          {
            "evidence_key": "confirmed_start_timestamp",
            "description": "confirmed start timestamp"
          },
          {
            "evidence_key": "live_treatment_and_control_ids",
            "description": "live treatment and control identifiers"
          },
          {
            "evidence_key": "audience_allocation",
            "description": "audience allocation"
          }
        ]
      },
      "complete": {
        "from": "running",
        "to": "completed",
        "rule_id": "RTE-EXP-005",
        "required_evidence": [
          {
            "evidence_key": "completion_event_id",
            "description": "completion event ID"
          },
          {
            "evidence_key": "observation_window_or_early_stop",
            "description": "observation window or predeclared early-stop trigger"
          },
          {
            "evidence_key": "result_dataset_ref",
            "description": "result dataset reference"
          },
          {
            "evidence_key": "actual_sample",
            "description": "actual sample"
          },
          {
            "evidence_key": "metric_result",
            "description": "metric result"
          },
          {
            "evidence_key": "quality_checks",
            "description": "quality checks"
          }
        ]
      },
      "cancel": {
        "from_any": [
          "proposed",
          "approved",
          "instrumented",
          "running"
        ],
        "to": "cancelled",
        "rule_id": "RTE-EXP-006",
        "required_evidence": [
          {
            "evidence_key": "cancellation_event_id",
            "description": "cancellation event ID"
          },
          {
            "evidence_key": "actor",
            "description": "actor"
          },
          {
            "evidence_key": "reason",
            "description": "reason"
          },
          {
            "evidence_key": "timestamp",
            "description": "timestamp"
          },
          {
            "evidence_key": "collected_data_impact",
            "description": "impact on already collected data"
          }
        ]
      },
      "invalidate": {
        "from_any": [
          "instrumented",
          "running",
          "completed"
        ],
        "to": "invalidated",
        "rule_id": "RTE-EXP-007",
        "required_evidence": [
          {
            "evidence_key": "invalidation_event_id",
            "description": "invalidation event ID"
          },
          {
            "evidence_key": "integrity_defect",
            "description": "integrity defect"
          },
          {
            "evidence_key": "affected_data",
            "description": "affected data"
          },
          {
            "evidence_key": "actor",
            "description": "actor"
          },
          {
            "evidence_key": "timestamp",
            "description": "timestamp"
          },
          {
            "evidence_key": "remediation_or_replacement_ref",
            "description": "remediation or replacement experiment reference"
          }
        ]
      }
    }
  }
}
