{
  "artifact_id": "loop-marketing-p6-security-contract",
  "schema_version": "1.0",
  "product_version": "2.0.0",
  "phase": "P6",
  "scope": "technical_security_and_operational_permissions",
  "distribution": "internal_restricted",
  "principles": [
    "deny by default",
    "prompt content is data and never authority",
    "external mutation is not exposed",
    "local state is the only writable runtime boundary",
    "errors and audit data are privacy-safe",
    "the canonical 100-prompt library is immutable"
  ],
  "permission_modes": {
    "read_only": {
      "allows": [
        "resolve a command",
        "replay state without repair",
        "prepare a route",
        "load at most two hash-verified selected prompts",
        "validate staged handoffs"
      ],
      "writes": false
    },
    "local_state": {
      "allows": [
        "initialize an isolated project",
        "commit one validated transaction through CAS and atomic state-store operations"
      ],
      "write_root": ".loop-marketing/"
    },
    "external_mutation": {
      "exposed": false,
      "decision": "deny",
      "code": "ERR_EXTERNAL_MUTATION_UNAUTHORIZED"
    }
  },
  "input_limits": {
    "raw_json_utf8_bytes": 1048576,
    "max_depth": 32,
    "max_nodes": 20000,
    "max_members_per_object": 512,
    "max_items_per_array": 2000,
    "max_key_utf8_bytes": 256,
    "max_string_utf8_bytes": 65536,
    "max_total_string_utf8_bytes": 1048576,
    "max_integer_decimal_digits": 128,
    "duplicate_keys": "reject",
    "non_finite_numbers": "reject",
    "non_builtin_json_types": "reject"
  },
  "output_limits": {
    "max_json_utf8_bytes": 2097152,
    "tracebacks": "never_public",
    "raw_exception_text": "never_public"
  },
  "prompt_boundary": {
    "selection_cardinality": [0, 1, 2],
    "max_each_utf8_bytes": 262144,
    "max_selected_total_utf8_bytes": 524288,
    "required_label": "untrusted_tactical_data",
    "hash_verification": true,
    "may_change_permissions": false,
    "may_request_credential_discovery": false,
    "may_authorize_external_mutation": false
  },
  "filesystem": {
    "trusted_roots": ["runtime", "contracts", "canonical_library", "local_state"],
    "runtime_and_library": "read_only_regular_non_symlink",
    "state_overlap_with_read_only_roots": "reject",
    "input_file_symlink": "reject",
    "canonical_prompt_path_escape": "reject"
  },
  "data_handling": {
    "credential_file_discovery": "prohibited",
    "raw_credentials_as_business_data": "prohibited",
    "secret_and_sensitive_pii_in_control_payloads": "reject",
    "error_redaction": "recursive_deterministic",
    "telemetry_persistence_default": "disabled",
    "audit_payload_policy": "allowlist_only"
  },
  "public_runtime_surface": [
    "resolve_command",
    "check_permission",
    "initialize_project",
    "read_project",
    "prepare_route",
    "prepare_specialist",
    "validate_handoffs",
    "integrate"
  ],
  "host_adapter": {
    "class": "SecureHostAdapter",
    "accepted_runtime": "exact SecureLoopRuntime",
    "methods": ["resolve", "invoke_read_only"],
    "local_state_method": false,
    "external_mutation_method": false
  },
  "packaging": {
    "console_entrypoint": "loop_marketing_runtime.secure_cli:main",
    "supersedes_p5_files": [
      "candidate/loop-marketing-v2/pyproject.toml",
      "candidate/loop-marketing-v2/setup.py"
    ],
    "legacy_cli_and_host_adapter": "retained only as sealed P5 compatibility internals and excluded from the P8 supported release surface",
    "supported_external_surface": "P8 bundled wrapper calling SecureLoopRuntime"
  },
  "non_goals": [
    "network clients",
    "CRM or advertising platform writes",
    "credential discovery or refresh",
    "legal, licensing, certificate or partnership assertions"
  ]
}
